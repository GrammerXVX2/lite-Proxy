# Base fallback URL (used if model-specific base_url is missing)
VLLM_BASE_URL=http://127.0.0.1:8003/v1

# Default aliases used when request body does not pass model
DEFAULT_EMBED_MODEL=lainlives/Qwen3-Embedding-4B-bnb-4bit
DEFAULT_RERANK_MODEL=Qwen/Qwen3-Reranker-0.6B
DEFAULT_CHAT_MODEL=cyankiwi/Qwen3.5-9B-AWQ-4bit

# Model routing for liteProxy (DB-free) from external JSON file.
# You can switch 127.0.0.1 to 0.0.0.0 in models.json if needed.
LITE_MODEL_CONFIG_FILE=models.json

UPSTREAM_TIMEOUT_SECONDS=30
UPSTREAM_RETRY_ATTEMPTS=2
UPSTREAM_RETRY_STATUS_CODES=502,503,504
